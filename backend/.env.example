# Used for accessing research paper contents
TAVILY_API_KEY=

# Every time the graph runs, LangChain automatically ships a full trace to LangSmith — no code changes needed. You get:

# Every node that ran, in order, with timing
# The exact prompt sent to Gemini at each node
# The structured output it returned
# Which tool was selected by the planner, what it returned
# The full AgentState at each step
# You view this at smith.langchain.com → project KnowledgePilot. Useful for debugging why a query routed wrong or why the grader said "insufficient".
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=KnowledgePilot

#Llama Index API KEY
LLAMA_CLOUD_API_KEY=

#LLM PROVIDER SELECTION
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

#GROQ MOdel API KEY
GROQ_API_KEY=

#Gemini Model API KEY
GOOGLE_API_KEY= 

GOOGLE_CLOUD_PROJECT= knowledge-pilot-agentic-rag

#If deploy to Streamlit Cloud specifically in the future,
# Go to App settings → Secrets and paste this (use TOML):

# GOOGLE_API_KEY = "AIza..."
# TAVILY_API_KEY = "tvly-..."
# LANGCHAIN_API_KEY = "ls__..."
# LANGCHAIN_TRACING_V2 = "true"
# LANGCHAIN_PROJECT = "KnowledgePilot"
# FIRESTORE_PROJECT_ID = "your-project-id"
# FIRESTORE_CREDENTIALS_JSON = '{"type":"service_account","project_id":"..."}'
# Streamlit exposes these as os.environ vars, so code needs zero changes.
